NODE_ENV=development
PORT=5000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mems

JWT_ACCESS_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

CORS_ORIGIN_USER=http://localhost:3000
CORS_ORIGIN_ADMIN=http://localhost:3001
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=MEMS <noreply@yourdomain.com>
FRONTEND_USER_BASE_URL=http://localhost:3000
EMAIL_VERIFY_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Maps/geocoding: handled in Next.js apps (Leaflet + MapTiler or OSM; LocationIQ or Geoapify). No Google Maps server key.
