NODE_ENV=production
PORT=5000

# Fill after RDS is created (URL-encode special chars in password)
DATABASE_URL=postgresql://maqaam_admin:YOUR_PASSWORD@YOUR_RDS_ENDPOINT.region.rds.amazonaws.com:5432/maqaam

JWT_ACCESS_SECRET=GENERATE_32_PLUS_RANDOM_CHARS
JWT_REFRESH_SECRET=GENERATE_ANOTHER_32_PLUS_RANDOM_CHARS
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

CORS_ORIGIN_USER=https://maqaam.me
CORS_ORIGIN_ADMIN=https://admin.maqaam.me
COOKIE_SECURE=true
TRUST_PROXY=true

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Maqaam <noreply@maqaam.me>
FRONTEND_USER_BASE_URL=https://maqaam.me
EMAIL_VERIFY_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
